    },
    "docs-gate": {
      "command": "/Users/nguyenhuuanh/.cargo/bin/docs-gate",
      "args": ["serve"]
    },
    "ship": {
      "command": "/Users/nguyenhuuanh/.cargo/bin/ship",
      "args": ["serve"]
    }
  }
